# ===========================================
# Expense Tracker — Environment Variables
# ===========================================

# --- Backend (Spring Boot / Render) ---
PORT=8080

# Local PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/expense_tracker
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password_here

# Render auto-injects DATABASE_URL when linked to PostgreSQL
# DATABASE_URL=postgresql://user:pass@host:5432/expense_tracker

DDL_AUTO=update
SHOW_SQL=false

# Comma-separated allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# --- Docker Compose ---
POSTGRES_PASSWORD=postgres

# --- Frontend (Vite / Vercel) ---
VITE_API_URL=http://localhost:8080
